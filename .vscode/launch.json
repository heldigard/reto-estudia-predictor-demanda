{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "[WSL Remote Only] Backend API :8001",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}",
      "python": "${command:python.interpreterPath}",
      "args": [
        "backend.app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8001",
        "--reload"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "[WSL Remote Only] Frontend Static Server :4173",
      "type": "python",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "python": "${command:python.interpreterPath}",
      "module": "http.server",
      "args": [
        "4173",
        "--directory",
        "frontend"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "[WSL Remote Only] Frontend + Backend",
      "configurations": [
        "[WSL Remote Only] Backend API :8001",
        "[WSL Remote Only] Frontend Static Server :4173"
      ]
    }
  ]
}
